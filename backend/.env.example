# PostgreSQL connection string (Render/Supabase/local)
DATABASE_URL="postgresql://user:password@localhost:5432/kailabs?schema=public"

# Random 64-hex-char secret used to sign JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me"

# Master key used to encrypt user-provided AI API keys at rest (any long random string works).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_KEY="change-me"

# Base URL this backend is served at (used to build extension-connect links).
APP_BASE_URL="http://localhost:3000"

PORT=3000
