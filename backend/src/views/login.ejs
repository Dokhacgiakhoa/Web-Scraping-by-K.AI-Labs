<% var title = 'Log in - K.AI Labs' %>
<%- include('partials/layout-head', { title }) %>

<h1>Web Scraping by K.AI Labs</h1>
<p class="muted">Log in, then connect the Chrome extension from your dashboard.</p>

<form id="login-form">
  <label>Email <input type="email" name="email" required /></label>
  <label>Password <input type="password" name="password" required /></label>
  <button type="submit">Log in</button>
</form>
<p id="form-error" class="error"></p>
<p class="muted">No account? <a href="/signup">Sign up</a></p>

<script>
  document.getElementById('login-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = new FormData(e.target);
    const res = await fetch('/api/auth/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: form.get('email'), password: form.get('password') }),
    });
    const data = await res.json();
    if (!res.ok) {
      document.getElementById('form-error').textContent = data.error || 'Login failed';
      return;
    }
    window.location.href = '/dashboard';
  });
</script>

<%- include('partials/layout-foot') %>
