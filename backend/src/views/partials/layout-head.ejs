<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= typeof title !== 'undefined' ? title : 'K.AI Labs' %></title>
  <style>
    :root { color-scheme: light dark; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      max-width: 640px;
      margin: 48px auto;
      padding: 0 20px;
      line-height: 1.5;
    }
    h1 { font-size: 1.5rem; }
    label { display: block; margin-top: 12px; font-size: 0.9rem; }
    input, select {
      width: 100%;
      padding: 8px;
      margin-top: 4px;
      box-sizing: border-box;
      font-size: 1rem;
    }
    button {
      margin-top: 16px;
      padding: 10px 16px;
      font-size: 1rem;
      cursor: pointer;
    }
    .error { color: #c0392b; margin-top: 12px; }
    .card { border: 1px solid #8883; border-radius: 8px; padding: 16px; margin-top: 16px; }
    .muted { opacity: 0.7; font-size: 0.85rem; }
    a { color: #2563eb; }
    code { background: #8882; padding: 2px 6px; border-radius: 4px; }
  </style>
</head>
<body>
